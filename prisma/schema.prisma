// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  files         UserFile[]
  jobs          Job[]
  notifications Notification[]
  favorites     Favorite[]
  chatSessions  ChatSession[]
  dailyCredits    Int       @default(50) @map("daily_credits")
  lifetimeCredits Int       @default(0)  @map("lifetime_credits")
  
  // Usage Tracking
  plan              String    @default("free") // "free" | "pro"
  subscriptionId    String?
  subscriptionStatus String   @default("none") @map("subscription_status") // "none" | "active" | "cancelled"
  planExpiresAt     DateTime? @map("plan_expires_at")
  
  aiMessagesToday   Int       @default(0)  @map("ai_messages_today")
  aiMessagesReset   DateTime? @map("ai_messages_reset")
  creditsLastReset  DateTime? @map("credits_last_reset")
  
  aiGenerationsUsed Int       @default(0)
  aiGenerationsLimit Int      @default(50)
  nextResetDate     DateTime?
  
  context       UserContext?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model UserContext {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeProject String?  // e.g. "Discord Bot"
  recentFiles   String?  // JSON string
  preferences   String?  // JSON string
  memories      String?  // Long term context/notes
  lastUpdated   DateTime @default(now()) @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   // success, info, warning
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model UserFile {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolType      String   // e.g. "magic-eraser", "vocal-remover", "ai-image-generator"
  originalName  String
  originalUrl   String?
  resultUrl     String?
  fileType      String   // image, audio, video, pdf, etc.
  status        String   // "completed", "failed", "processing"
  createdAt     DateTime @default(now())
  metadata      Json?    // extra info like prompt, size, etc.
}

model Job {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolType     String    // bg-remove, pdf-merge, etc.
  status       JobStatus @default(PENDING)
  progress     Int       @default(0)
  originalUrl  String?
  resultUrl    String?
  error        String?
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// NextAuth models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolId    String   // The ID or slug of the tool
  createdAt DateTime @default(now())

  @@unique([userId, toolId])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("New Chat")
  messages  String   // JSON string of messages to avoid Prisma Json type issues with complex objects in SQLite
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
